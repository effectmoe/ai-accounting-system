# MongoDB Atlas (Primary Database)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/accounting?retryWrites=true&w=majority

# Azure Form Recognizer (OCR - Replaces Google Vision/GAS)
AZURE_FORM_RECOGNIZER_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=your-azure-key-here

# AI Models
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key

# HandwritingOCR API (Maintained for handwritten text)
HANDWRITING_OCR_API_TOKEN=your-handwriting-ocr-api-token

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 旧設定（移行期間中のみ保持）
# Supabase (Deprecated - Migrating to MongoDB)
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Apps Script OCR (Deprecated - Replaced by Azure)
# GAS_OCR_URL=https://script.google.com/macros/s/...
# GAS_PROJECT_ID=...
# GAS_CLIENT_ID=your-gas-client-id
# GAS_CLIENT_SECRET=your-gas-client-secret
# GAS_REDIRECT_URI=http://localhost:3000/auth/callback
# GAS_TOKEN_PATH=./tokens.json

# Google Drive API (Deprecated - Files now stored in MongoDB GridFS)
# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# GOOGLE_PRIVATE_KEY_ID=your-private-key-id
# GOOGLE_PRIVATE_KEY=your-private-key
# GOOGLE_CLIENT_EMAIL=your-client-email
# GOOGLE_CLIENT_ID=your-client-id

# MCP Servers - Problem Solving Agent
PERPLEXITY_API_KEY=your-perplexity-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
DATAFORSEO_API_KEY=your-dataforseo-api-key
MIDSCENE_API_KEY=your-midscene-api-key
MIDSCENE_CHROME_EXTENSION_ID=your-chrome-extension-id

# NLWeb Integration
NLWEB_API_KEY=your-nlweb-api-key
NLWEB_SITE_URL=your-nlweb-site-url

# GitHub/Vercel (for deployment)
GITHUB_TOKEN=your-github-token
VERCEL_TOKEN=your-vercel-token